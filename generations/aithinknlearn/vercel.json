{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "frontend/index.html"
    },
    {
      "src": "/phonetic",
      "dest": "frontend/phonetic-verification.html"
    },
    {
      "src": "/rag",
      "dest": "frontend/rag-demo.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
